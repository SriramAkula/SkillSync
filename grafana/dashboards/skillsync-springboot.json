{
  "title": "SkillSync - Spring Boot Metrics",
  "uid": "skillsync-springboot",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "application",
        "type": "query",
        "label": "Application",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": { "query": "label_values(jvm_info, application)", "refId": "A" },
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
        "query": { "query": "label_values(jvm_info{application=\"$application\"}, instance)", "refId": "B" },
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Uptime",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [{ "expr": "process_uptime_seconds{application=\"$application\", instance=\"$instance\"}", "refId": "A" }]
    },
    {
      "id": 2, "type": "stat", "title": "Start Time",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "dateTimeAsIso" } },
      "targets": [{ "expr": "process_start_time_seconds{application=\"$application\", instance=\"$instance\"}*1000", "refId": "A" }]
    },
    {
      "id": 3, "type": "gauge", "title": "Heap Used %",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green" }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 }] } } },
      "targets": [{ "expr": "sum(jvm_memory_used_bytes{application=\"$application\", instance=\"$instance\", area=\"heap\"})*100/sum(jvm_memory_max_bytes{application=\"$application\", instance=\"$instance\", area=\"heap\"})", "refId": "A" }]
    },
    {
      "id": 4, "type": "stat", "title": "CPU Usage",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [{ "expr": "process_cpu_usage{application=\"$application\", instance=\"$instance\"}", "refId": "A" }]
    },
    {
      "id": 5, "type": "stat", "title": "Live Threads",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "jvm_threads_live_threads{application=\"$application\", instance=\"$instance\"}", "refId": "A" }]
    },
    {
      "id": 6, "type": "stat", "title": "Classes Loaded",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [{ "expr": "jvm_classes_loaded_classes{application=\"$application\", instance=\"$instance\"}", "refId": "A" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "CPU Usage",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "percentunit" } },
      "targets": [
        { "expr": "process_cpu_usage{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Process CPU", "refId": "A" },
        { "expr": "system_cpu_usage{application=\"$application\", instance=\"$instance\"}", "legendFormat": "System CPU", "refId": "B" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "JVM Memory Used",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "expr": "jvm_memory_used_bytes{application=\"$application\", instance=\"$instance\", area=\"heap\"}", "legendFormat": "Heap - {{id}}", "refId": "A" },
        { "expr": "jvm_memory_used_bytes{application=\"$application\", instance=\"$instance\", area=\"nonheap\"}", "legendFormat": "Non-Heap - {{id}}", "refId": "B" }
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "HTTP Request Rate",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "targets": [
        { "expr": "irate(http_server_requests_seconds_count{application=\"$application\", instance=\"$instance\", uri!~\".*(prometheus|health).*\"}[1m])", "legendFormat": "{{method}} {{status}} {{uri}}", "refId": "A" }
      ]
    },
    {
      "id": 10, "type": "timeseries", "title": "HTTP Response Time",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "irate(http_server_requests_seconds_sum{application=\"$application\", instance=\"$instance\", uri!~\".*(prometheus|health).*\"}[1m]) / irate(http_server_requests_seconds_count{application=\"$application\", instance=\"$instance\", uri!~\".*(prometheus|health).*\"}[1m])", "legendFormat": "{{method}} {{uri}}", "refId": "A" }
      ]
    },
    {
      "id": 11, "type": "timeseries", "title": "JVM Threads",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "jvm_threads_live_threads{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Live", "refId": "A" },
        { "expr": "jvm_threads_daemon_threads{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Daemon", "refId": "B" },
        { "expr": "jvm_threads_peak_threads{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Peak", "refId": "C" }
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "GC Pause Duration",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "targets": [
        { "expr": "irate(jvm_gc_pause_seconds_sum{application=\"$application\", instance=\"$instance\"}[1m])", "legendFormat": "{{action}} [{{cause}}]", "refId": "A" }
      ]
    },
    {
      "id": 13, "type": "timeseries", "title": "HikariCP Connections",
      "gridPos": { "x": 0, "y": 27, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "hikaricp_connections_active{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Active", "refId": "A" },
        { "expr": "hikaricp_connections_idle{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Idle", "refId": "B" },
        { "expr": "hikaricp_connections_pending{application=\"$application\", instance=\"$instance\"}", "legendFormat": "Pending", "refId": "C" }
      ]
    },
    {
      "id": 14, "type": "timeseries", "title": "Logback Events",
      "gridPos": { "x": 12, "y": 27, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        { "expr": "irate(logback_events_total{application=\"$application\", instance=\"$instance\", level=\"error\"}[1m])", "legendFormat": "ERROR", "refId": "A" },
        { "expr": "irate(logback_events_total{application=\"$application\", instance=\"$instance\", level=\"warn\"}[1m])", "legendFormat": "WARN", "refId": "B" },
        { "expr": "irate(logback_events_total{application=\"$application\", instance=\"$instance\", level=\"info\"}[1m])", "legendFormat": "INFO", "refId": "C" }
      ]
    }
  ]
}
