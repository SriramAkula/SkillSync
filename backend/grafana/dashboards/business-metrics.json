{
  "title": "Business Metrics",
  "uid": "business-metrics",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "New Groups Created",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-skillsync"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count_over_time({service=\"group-service\"} |= \"created\" [24h])"
        }
      ]
    },
    {
      "id": 2,
      "title": "Mentors Signed Up",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 5
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-skillsync"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count_over_time({service=\"mentor-service\"} |= \"joined\" [24h])"
        }
      ]
    },
    {
      "id": 3,
      "title": "Reviews Added",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 4,
        "h": 5
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-skillsync"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count_over_time({service=\"review-service\"} |= \"review added\" [24h])"
        }
      ]
    },
    {
      "id": 4,
      "title": "Emails Delivered",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 4,
        "h": 5
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-skillsync"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count_over_time({service=\"notification-service\"} |= \"sent successfully\" [24h])"
        }
      ]
    },
    {
      "id": 5,
      "title": "Messages Sent Rate",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(http_server_requests_seconds_count{job=\"messaging-service\"}[5m])"
        }
      ]
    }
  ],
  "templating": {
    "list": []
  }
}