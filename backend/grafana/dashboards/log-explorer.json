{
  "title": "Log Explorer",
  "uid": "log-explorer",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Dynamic Service Filter",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-skillsync"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=\"$service\"}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false
      }
    },
    {
      "id": 2,
      "title": "Global Error Logs",
      "type": "logs",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-skillsync"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\"$service\"} |= \"ERROR\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false
      }
    },
    {
      "id": 3,
      "title": "RabbitMQ Pub/Sub",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-skillsync"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\"$service\"} |= \"Publishing\" or {service=~\"$service\"} |= \"Consuming\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false
      }
    },
    {
      "id": 4,
      "title": "Feign Errors",
      "type": "logs",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki-skillsync"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{service=~\"$service\"} |= \"FeignException\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "custom",
        "query": "auth-service, user-service, skill-service, session-service, mentor-service, group-service, review-service, notification-service, payment-gateway, messaging-service, api-gateway, .*",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  }
}