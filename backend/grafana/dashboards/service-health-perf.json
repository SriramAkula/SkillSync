{
  "title": "Service Health & Performance",
  "uid": "service-health-perf",
  "timezone": "browser",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate by Status Code",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"$service\"}[1m]))"
        }
      ]
    },
    {
      "id": 2,
      "title": "P99 Latency",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"$service\"}[5m]))) * 1000"
        }
      ]
    },
    {
      "id": 3,
      "title": "P90 Latency",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.90, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"$service\"}[5m]))) * 1000"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error Count by URI",
      "type": "table",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (uri, status) (rate(http_server_requests_seconds_count{job=\"$service\", status=~\"4..|5..\"}[5m])))"
        }
      ]
    },
    {
      "id": 5,
      "title": "JVM Memory - All",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "jvm_memory_used_bytes{job=\"$service\"}"
        }
      ]
    },
    {
      "id": 6,
      "title": "GC Pause Time",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(jvm_gc_pause_seconds_sum{job=\"$service\"}[1m])"
        }
      ]
    },
    {
      "id": 7,
      "title": "CPU Usage",
      "type": "gauge",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "process_cpu_usage{job=\"$service\"} * 100"
        }
      ]
    },
    {
      "id": 8,
      "title": "DB Connection Active",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 24,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active{job=\"$service\"}"
        }
      ]
    },
    {
      "id": 9,
      "title": "DB Connection Pending",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 4,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_pending{job=\"$service\"}"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "query": "label_values(up, job)",
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  }
}